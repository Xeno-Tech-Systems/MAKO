fn find_first_even(xs) {
    for x in xs {
        if x % 2 == 0 { return x; }
    }
    return -1;
}

fn sum_until_negative(xs) {
    total = 0;
    for x in xs {
        if x < 0 { break; }
        total = total + x;
    }
    return total;
}

fn count_positive_in_nested(grid) {
    count = 0;
    for row in grid {
        for cell in row {
            if cell <= 0 { continue; }
            count = count + 1;
        }
    }
    return count;
}

fn early_return_in_while(n) {
    i = 0;
    while true {
        if i >= n { return i; }
        i = i + 1;
    }
}

fn return_from_try(x) {
    try {
        if x < 0 { return "negative"; }
        return "non-negative";
    } catch err {
        return "caught";
    }
}

main() {
    assert(find_first_even([1, 3, 5, 8, 9]) == 8, "return from inside for-loop");
    assert(find_first_even([1, 3, 5]) == -1, "loop completes, falls to final return");

    assert(sum_until_negative([1, 2, 3, -1, 100]) == 6, "break inside for-loop, then function continues");

    grid = [[1, -1, 2], [-3, 4, 0], [5, -5, 6]];
    assert(count_positive_in_nested(grid) == 5, "continue inside nested for-loops");

    assert(early_return_in_while(7) == 7, "return from inside an infinite while loop");

    assert(return_from_try(-5) == "negative", "return from inside a try block");
    assert(return_from_try(5) == "non-negative", "return from inside a try block, other branch");

    # break/continue across an outer/inner loop boundary
    outer_hits = 0;
    for i in [1, 2, 3] {
        for j in [1, 2, 3] {
            if j == 2 { break; }
            outer_hits = outer_hits + 1;
        }
    }
    assert(outer_hits == 3, "break only exits the innermost loop, outer loop continues");

    # a function called inside a loop condition, using its own return internally,
    # must not corrupt the outer loop's own flow state
    is_small = fn(n) { if n < 5 { return true; } return false; };
    total = 0;
    k = 0;
    while is_small(k) {
        total = total + k;
        k = k + 1;
    }
    assert(total == 10, "nested function call with its own return doesn't corrupt an outer while loop"); # 0+1+2+3+4

    # break/continue outside any loop must be a normal catchable error,
    # not an interpreter crash, and must not corrupt later execution.
    caught_break = false;
    try {
        bad = fn() { break; };
        bad();
    } catch err {
        caught_break = true;
        assert(contains(err, "break"), "the error names 'break'");
    }
    assert(caught_break, "break outside a loop is a catchable error");

    caught_continue = false;
    try {
        bad2 = fn() { continue; };
        bad2();
    } catch err2 {
        caught_continue = true;
        assert(contains(err2, "continue"), "the error names 'continue'");
    }
    assert(caught_continue, "continue outside a loop is a catchable error");

    # execution must continue normally after those caught errors
    assert(1 + 1 == 2, "interpreter state is still healthy after a caught break/continue error");

    print "flow stress tests pass!";
}
