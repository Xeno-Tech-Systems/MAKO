fn add(a, b) {
    return a + b;
}

fn no_return() {
    x = 1;
}

fn factorial(n) {
    if n <= 1 { return 1; }
    return n * factorial(n - 1);
}

fn make_counter_start() {
    return 0;
}

main() {
    assert(add(2, 3) == 5, "basic call");
    assert(no_return() == none, "implicit none return");
    assert(factorial(5) == 120, "recursion");
    assert(factorial(1) == 1, "recursion base case");

    # Lambdas — arrow form
    square = fn(x) => x * x;
    assert(square(5) == 25, "arrow lambda");

    # Lambdas — block form
    describe = fn(x) {
        if x > 0 { return "positive"; }
        return "non-positive";
    };
    assert(describe(5) == "positive", "block lambda true branch");
    assert(describe(0) == "non-positive", "block lambda false branch");

    # Closures capture surrounding scope
    base = 10;
    add_base = fn(x) => x + base;
    assert(add_base(5) == 15, "closure captures variable");

    base = 100;
    assert(add_base(5) == 15, "closure captured by value at creation, not live reference");

    # Passing lambdas as values
    apply_twice = fn(f, x) { return f(f(x)); };
    assert(apply_twice(fn(n) => n + 1, 5) == 7, "lambda as argument");

    # Functions calling functions
    assert(add(add(1, 2), 3) == 6, "function calling function");
}
