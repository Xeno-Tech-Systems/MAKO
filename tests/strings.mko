main() {
    s = "hello";
    assert(len(s) == 5, "len");
    assert(upper(s) == "HELLO", "upper");
    assert(lower("WORLD") == "world", "lower");
    assert(trim("  hi  ") == "hi", "trim");
    assert(contains(s, "ell"), "contains true");
    assert(not contains(s, "xyz"), "contains false");
    assert(starts_with(s, "he"), "starts_with");
    assert(ends_with(s, "lo"), "ends_with");
    assert(replace(s, "l", "L") == "heLLo", "replace");
    assert(s[0] == "h", "index");
    assert(s + " world" == "hello world", "concat");
    assert(slice(s, 1, 3) == "el", "slice");

    parts = split("a,b,c", ",");
    assert(len(parts) == 3, "split len");
    assert(parts[1] == "b", "split content");
    assert(join(parts, "-") == "a-b-c", "join");

    n = 5;
    name = "Robin";
    assert("Hi {name}, you are {n}" == "Hi Robin, you are 5", "interpolation");
    assert("{1 + 1}" == "2", "interpolation expr");
    escaped = "literal {{brace}}";
    assert(len(escaped) == 15, "escaped braces produce literal braces");
    assert(contains(escaped, "{{brace}}"), "escaped braces content");

    d = {"key": "value"};
    assert("nested {d["key"]}" == "nested value", "interpolation with dict index");

    items = ["x", "y"];
    assert("first: {items[0]}" == "first: x", "interpolation with list index");

    assert(to_str(42) == "42", "to_str number");
    assert(to_num("42") == 42, "to_num string");
}
